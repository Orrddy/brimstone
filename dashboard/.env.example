APP_NAME=BrimStone
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_VERSION="1.2.2"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (Aiven MySQL or local MySQL) ───────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=your-aiven-mysql-host.aivencloud.com
DB_PORT=3306
DB_DATABASE=brimstone
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
# Aiven requires SSL — set path to CA cert downloaded from Aiven console
DB_SSL_CA=/path/to/aiven-ca.pem

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_ENCRYPTION=tls
MAIL_HOST=smtp.your-mail-provider.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM_ADDRESS=noreply@brimstonebrokers.com
MAIL_FROM_NAME=BrimStone

# ─── Storage (optional S3-compatible) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── reCAPTCHA ───────────────────────────────────────────────────────────────
NOCAPTCHA_SECRET=your_recaptcha_secret
NOCAPTCHA_SITEKEY=your_recaptcha_site_key

APP_TIMEZONE=Europe/London

APPEND_DATE_TO_EMAILS=disabled

SEARCH_ENGINE_INDEXING=true

PRODUCT_KEY=your_product_key

# ─── OAuth Social Login (optional) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/login/google/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL="${APP_URL}/login/github/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL="${APP_URL}/login/facebook/callback"

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URL="${APP_URL}/login/twitter/callback"

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URL="${APP_URL}/login/linkedin/callback"

USE_VITE=

# ─── Payment Gateways (configure as needed) ──────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=usd

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PAYMENT_URL=https://api.paystack.co
PAYSTACK_DEFAULT_CURRENCY=USD
PAYSTACK_MERCHANT_EMAIL=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_DEFAULT_CURRENCY=USD

# ─── Template ────────────────────────────────────────────────────────────────
TEMPLATE="bento"
